# Backend — bind address (localhost only in local mode)
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# CORS: allow only the local frontend origin
CORS_ORIGIN=http://localhost:5173

# Ollama — server-controlled, never a user-supplied value (prevents SSRF)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=fredrezones55/chandra-ocr-2:patch

# Upload limits
MAX_FILE_SIZE_MB=50
MAX_PAGES=50
