# Backend — bind address (localhost only in local mode)
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info

# CORS: allow only the local frontend origin
CORS_ORIGIN=http://localhost:5173

# Ollama — server-controlled, never a user-supplied value (prevents SSRF)
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL=fredrezones55/chandra-ocr-2:patch
# Text model used for field extraction (Phase 3). Any instruction-following model works.
OLLAMA_EXTRACTION_MODEL=llama3.2
OLLAMA_EXTRACTION_TIMEOUT_MS=120000

# Upload limits
MAX_FILE_SIZE_MB=50
MAX_PAGES=50

# Persistent job history (SQLite). Defaults to ~/.ocr-reader/jobs.db
# DB_PATH=/path/to/jobs.db
